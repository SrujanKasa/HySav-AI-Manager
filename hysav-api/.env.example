# HySav API — environment variables
# Copy to .env (or set in your host's env) — never commit real values.

# Port the API (and the static marketing site) is served on
PORT=3000

# Path to the SQLite database file. Created + migrated automatically on boot.
# For production the schema is written to be portable to Postgres — see README.
DATABASE_PATH=./data/hysav.db

# 64 hex chars (32 bytes). Used for AES-256-GCM encryption of stored
# integration credentials (users' OpenAI/Anthropic admin keys).
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# Base URL used in invite links and emails
BASE_URL=http://localhost:3000

# Transactional email (optional). If RESEND_API_KEY is unset, emails are
# written to the outbox table and logged to the console instead of sent.
RESEND_API_KEY=
EMAIL_FROM="HySav <alerts@hysav.app>"

# Set to 1 to auto-seed the demo workspace on boot when the DB is empty
SEED_ON_BOOT=1
