# HySav API — environment variables
# Copy to .env (or set in your host's env) — never commit real values.

# Port the API (and the static marketing site) is served on
PORT=3000

# MongoDB connection string (MongoDB Atlas: mongodb+srv://user:pass@cluster/...).
# REQUIRED in production/Vercel. Leave unset locally — an embedded dev MongoDB
# (mongodb-memory-server) starts automatically, persisted under ./data/mongo.
MONGODB_URI=
MONGODB_DB=hysav

# 64 hex chars (32 bytes). Used for AES-256-GCM encryption of stored
# integration credentials (users' OpenAI/Anthropic admin keys).
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# Base URL used in invite links and emails
BASE_URL=http://localhost:3000

# Transactional email (optional). If RESEND_API_KEY is unset, emails are
# written to the outbox table and logged to the console instead of sent.
RESEND_API_KEY=
EMAIL_FROM="HySav <alerts@hysav.app>"

# Google OAuth login (optional). Web client from Google Cloud Console →
# APIs & Services → Credentials. Authorized redirect URI must be:
#   <BASE_URL>/api/v1/auth/google/callback
# The "Continue with Google" button is hidden until both are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay billing (test mode keys from https://dashboard.razorpay.com → API Keys).
# Leave blank to keep billing endpoints in "not configured" mode.
# RAZORPAY_KEY_ID is publishable (rzp_test_...); the secret and webhook secret are not.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Secret for the scheduled-jobs endpoint (/api/v1/jobs/daily). On Vercel,
# setting this env var makes Vercel Cron send it as a Bearer token
# automatically. Generate like APP_ENCRYPTION_KEY.
CRON_SECRET=

# Set to 1 to auto-seed the demo workspace on boot when the DB is empty
SEED_ON_BOOT=1

# DEV/TEST ONLY: password for the QA login hynexsbusiness@gmail.com.
# If unset, the QA account is not created. Ignored entirely in production
# (NODE_ENV=production). Never commit a real value here.
SEED_TEST_USER_PASSWORD=
